# ============================================================
# Dokat API Gateway — environment variables
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.
# ============================================================

# ------------------------------------------------------------------
# Auth (required)
# ------------------------------------------------------------------
FIREBASE_CREDENTIALS_PATH=/path/to/firebase-service-account.json
JWT_SECRET_KEY=change-me-use-at-least-32-random-chars

# Optional (defaults shown)
JWT_EXPIRY_MINUTES=15

# ------------------------------------------------------------------
# Storage (required)
# ------------------------------------------------------------------
REDIS_URL=redis://redis:6379/0

# ------------------------------------------------------------------
# Proxy (optional)
# ------------------------------------------------------------------
UPSTREAM_TIMEOUT_SECONDS=30

# ------------------------------------------------------------------
# Rate limits (optional — defaults shown)
# ------------------------------------------------------------------
RATE_LIMIT_USER_PER_MIN=200
RATE_LIMIT_IP_PER_MIN=30
RATE_LIMIT_GLOBAL_PER_MIN=10000
RATE_LIMIT_CAPTURE_PER_MIN=20

# ------------------------------------------------------------------
# Upstream service base URLs (required)
# ------------------------------------------------------------------
UPSTREAM_USER_SERVICE_URL=http://user-service:8000
UPSTREAM_PET_SERVICE_URL=http://pet-service:8000
UPSTREAM_POST_SERVICE_URL=http://post-service:8000
UPSTREAM_SOCIAL_SERVICE_URL=http://social-service:8000
UPSTREAM_CAPTURE_SERVICE_URL=http://capture-service:8000
UPSTREAM_SEND_SERVICE_URL=http://send-service:8000
UPSTREAM_VIEW_SERVICE_URL=http://view-service:8000
UPSTREAM_RESPONSE_SERVICE_URL=http://response-service:8000
UPSTREAM_HISTORY_SERVICE_URL=http://history-service:8000
UPSTREAM_ONBOARDING_SERVICE_URL=http://onboarding-service:8000
UPSTREAM_NOTIFICATION_SERVICE_URL=http://notification-service:8000
UPSTREAM_SETTING_SERVICE_URL=http://setting-service:8000
UPSTREAM_AI_API_URL=https://api.ai-provider.example.com

# ------------------------------------------------------------------
# Third-party AI (required if /ai/* route is enabled)
# ------------------------------------------------------------------
AI_API_KEY=

# ------------------------------------------------------------------
# Health check (optional)
# ------------------------------------------------------------------
HEALTH_PROBE_TIMEOUT_SECONDS=5

# ------------------------------------------------------------------
# Observability (optional)
# ------------------------------------------------------------------
LOG_LEVEL=INFO
