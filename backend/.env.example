# ──────────────────────────────────────────────
# ME Backend — Environment Variables
# Copy to .env and fill in the values.
# ──────────────────────────────────────────────

# ── Database ──────────────────────────────────
DATABASE_URL=postgresql+asyncpg://me_user:me_pass@localhost/me_dev

# ── Auth mode ─────────────────────────────────
# "jwt"      → standalone mode, no Firebase needed
# "firebase" → production mode with Firebase Auth
AUTH_MODE=jwt

# Required when AUTH_MODE=jwt
JWT_SECRET_KEY=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_DAYS=30

# Required when AUTH_MODE=firebase
# Paste the entire service account JSON as a single-line string.
FIREBASE_CREDENTIALS_JSON=

# ── Storage backend ───────────────────────────
# "minio" → self-hosted MinIO (default for local dev)
# "s3"    → AWS S3 + CloudFront CDN
STORAGE_BACKEND=minio

# MinIO (used when STORAGE_BACKEND=minio)
MINIO_ENDPOINT_URL=http://localhost:9000

# S3 / shared
S3_BUCKET=pawsnap
AWS_REGION=us-east-1

# CloudFront CDN base URL (used when STORAGE_BACKEND=s3)
CDN_BASE_URL=https://cdn.pawsnap.app

# AWS credentials (standard SDK env vars — not stored here)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# ── Redis ─────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── App ───────────────────────────────────────
DEBUG=false
DEEP_LINK_BASE=https://petapp.example.com

# ── Integration tests (Firebase emulator) ─────
# FIREBASE_AUTH_EMULATOR_HOST=localhost:9099
# FIREBASE_PROJECT_ID=demo-test
